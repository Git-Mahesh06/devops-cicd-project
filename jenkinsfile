pipeline {
    agent any

    stages {
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t prt-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker rm -f prt-container || true'
                sh 'docker run -d --name prt-container -p 8081:80 prt-app'
            }
        }
    }
}
