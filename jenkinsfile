pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/Git-Mahesh06/devops-cicd-project.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'sudo docker build -t prt-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'sudo docker run -d -p 8081:80 prt-app'
            }
        }
    }
}
